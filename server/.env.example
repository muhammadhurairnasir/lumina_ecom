NODE_ENV=production
PORT=5000

# Database — MongoDB Atlas free tier recommended
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/lumina?retryWrites=true&w=majority

# Auth — minimum 32 characters
JWT_SECRET=your_jwt_secret_minimum_32_characters_long
JWT_EXPIRE=30d

# Cloudinary (free tier: 25GB storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe (use test keys for demo)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get from Stripe Dashboard > Webhooks > Add endpoint > Signing Secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Email — Gmail SMTP with App Password (not account password)
# Enable 2FA on Gmail > Google Account > Security > App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_gmail_app_password_16_chars
FROM_EMAIL=youremail@gmail.com
FROM_NAME=Lumina Store

# Anthropic Claude AI
ANTHROPIC_API_KEY=sk-ant-...

# CORS — set to your Railway client URL after deploying client first
CLIENT_URL=https://your-client.up.railway.app
